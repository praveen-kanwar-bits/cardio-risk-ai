# ==================================================================================
# gitignore for Python Machine Learning Projects
#
# This file is designed to be a comprehensive starting point for Python projects,
# especially those involving data science, machine learning, and deep learning.
# It includes ignores for OS-specific files, Python artifacts, common tools,
# IDEs, and project-specific directories.
# ==================================================================================


# ----------------------------------------------------------------------------------
# Operating System Generated Files
#
# These are files generated automatically by macOS, Windows, and Linux.
# They don't belong in a shared repository.
# ----------------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*~
.*.swp
*.swp


# ----------------------------------------------------------------------------------
# IDE and Editor Configuration
#
# Ignoring configuration files for popular editors and IDEs helps avoid
# conflicts with other developers' settings.
# ----------------------------------------------------------------------------------
# JetBrains IDEs (PyCharm, IntelliJ, etc.)
.idea/

# Visual Studio Code
.vscode/
*.code-workspace

# Sublime Text
*.sublime-project
*.sublime-workspace

# Spyder
.spyderproject
.spyproject

# Rope
.ropeproject


# ----------------------------------------------------------------------------------
# Python Generated Files & Virtual Environments
#
# These files are generated by the Python interpreter, package managers,
# and virtual environment tools. They are machine-specific or can be regenerated.
# ----------------------------------------------------------------------------------
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# PEP 582; used by PDM, Pyflow, etc.
__pypackages__/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST


# ----------------------------------------------------------------------------------
# Package Manager Lock Files & Config
#
# It's often debated whether to commit lock files. For applications, you usually
# should to ensure reproducible builds. For libraries, you might not.
# We'll leave them commented out as a choice for the developer.
# ----------------------------------------------------------------------------------
# Pipenv
# Pipfile.lock

# Poetry
# poetry.lock

# PDM
# pdm.lock
# .pdm.toml
.pdm-python
.pdm-build/

# UV
# uv.lock

# Pixi
# pixi.lock
.pixi/


# ----------------------------------------------------------------------------------
# Project-Specific Files & Directories
#
# Ignore directories for data, logs, model checkpoints, and other outputs
# that are generated during runtime and should not be versioned.
# ----------------------------------------------------------------------------------
# Datasets (if stored locally and are large)
# data/
# datasets/

# Trained models and checkpoints
models/
checkpoints/
# *.pt (Commented out to allow model weights for assignment submission)
*.pth
*.h5
*.hdf5

# Output directories for experiments, plots, etc.
# outputs/ (Commented out to allow generated evidence for assignment submission)
results/

# Log files
logs/
*.log


# ----------------------------------------------------------------------------------
# Notebooks & Caches
#
# Ignore notebook checkpoints and various cache directories.
# ----------------------------------------------------------------------------------
# Jupyter Notebook
.ipynb_checkpoints

# General Caching
.cache/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# IPython
profile_default/
ipython_config.py


# ----------------------------------------------------------------------------------
# Testing & Code Quality
#
# Ignore reports and artifacts generated by testing, coverage, and linting tools.
# ----------------------------------------------------------------------------------
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pyre/
.pytype/
cython_debug/


# ----------------------------------------------------------------------------------
# Documentation
#
# Ignore built documentation files.
# ----------------------------------------------------------------------------------
# Sphinx
docs/_build/
# MkDocs
site/


# ----------------------------------------------------------------------------------
# Miscellaneous
#
# Other tool-specific files.
# ----------------------------------------------------------------------------------
# Scrapy
.scrapy

# PyInstaller
*.manifest
*.spec
